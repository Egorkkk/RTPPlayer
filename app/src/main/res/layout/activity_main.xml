<?xml version="1.0" encoding="utf-8"?>
<!-- Fullscreen SurfaceView for GStreamer video rendering.
     The "No Signal" TextView is shown when the stream is absent
     or an error is detected. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/root_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/black"
    android:keepScreenOn="true">

    <SurfaceView
        android:id="@+id/surface_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:keepScreenOn="true" />

    <!-- "No Signal" overlay — shown when no stream data is detected. -->
    <TextView
        android:id="@+id/no_signal_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:text="No Signal"
        android:textColor="#FFFFFF"
        android:textSize="24sp"
        android:visibility="gone" />

</FrameLayout>
